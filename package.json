{
  "name": "pixel-converter",
  "version": "1.0.0",
  "description": "Software de escritorio para conversion a pixel art",
  "author": "manup",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.manup.pixelconverter",
    "productName": "Pixel Converter",
    "extraFiles": [
      {
        "from": "motor_compilado",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "pig-icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "pig-icon.png"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}