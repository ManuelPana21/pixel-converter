{
  "name": "pixel-converter",
  "version": "1.0.0",
  "description": "Conversor de pixeles",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.pixelconverter.app",
    "win": {
      "target": "nsis",
      "icon": "pig-icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "pig-icon.png",
      "category": "Utility"
    },
    "extraResources": [
      {
        "from": "src/python/engine.exe",
        "to": "engine.exe"
      },
      {
        "from": "src/python/engine",
        "to": "engine"
      }
    ]
  },
  "author": "Manuel",
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}